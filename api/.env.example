# Render / production: set these in the dashboard (do not commit real `.env`).

DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

OPENAI_API_KEY=
GEMINI_API_KEY=

CORS_ORIGINS=https://your-app.vercel.app,http://localhost:3000,http://127.0.0.1:3000

# Optional: disable TLS hints for odd local setups only (not for Render/Supabase).
# DATABASE_SSL_DISABLE=1
